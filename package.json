{
  "name": "solidity-workbench",
  "private": true,
  "description": "Modern Solidity IDE plugin for VSCode/Cursor — Foundry-native, LSP-powered",
  "scripts": {
    "build": "pnpm build:icon && pnpm -r build",
    "build:icon": "node scripts/build-icon.mjs",
    "watch": "pnpm -r --parallel watch",
    "lint": "eslint packages/*/src/**/*.ts",
    "lint:fix": "eslint packages/*/src/**/*.ts --fix",
    "format": "prettier --write 'packages/*/src/**/*.ts'",
    "format:check": "prettier --check 'packages/*/src/**/*.ts'",
    "test": "pnpm -r test",
    "package": "pnpm build:icon && cd packages/extension && pnpm package",
    "clean": "pnpm -r clean"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.56.0",
    "prettier": "^3.8.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}
