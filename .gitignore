node_modules/
dist/
out/
# Forge's build cache, populated whenever `forge build` runs at the
# repo root (e.g. the indexer scaffold's auto-compile when the active
# project root IS the repo root).
cache/
# Forge dependency lockfile (written by forge 1.x alongside foundry.toml).
# Only the fixture project's lockfile should matter; the repo-root one is
# produced by no-op forge invocations and is meaningless.
foundry.lock
# Indexer scaffolds written by the `indexer.scaffold` / `subgraph.scaffold`
# command. The generator is pure — we don't track its output.
/subgraph/
/ponder/
/envio/
*.vsix
.vscode-test/
*.tsbuildinfo
.eslintcache
coverage/
.DS_Store
.cursor/

# Copied into the extension package by scripts/prepare-vsix-files.mjs
# at packaging time so the VSIX picks them up. The authoritative copies
# live at the repo root.
/packages/extension/README.md
/packages/extension/LICENSE
/packages/extension/CHANGELOG.md

# Stale tsc outputs that landed in src/ from older runs. The proper
# build path (`pnpm build:test`) emits to dist/test/ via tsconfig.test.json;
# anything emitted alongside the .ts sources is misconfigured cruft.
/packages/extension/src/test/**/*.js
/packages/extension/src/test/**/*.js.map
/packages/extension/src/test/**/*.d.ts
/packages/extension/src/test/**/*.d.ts.map

# Local planning notes.
/.plans/

# Foundry gas-regression baselines. They're tooling output, not source —
# users who want to commit one for regression tracking can `git add -f`.
**/.gas-snapshot

# vsce-generated package manifest — recreated on every `pnpm package`.
/vsixmanifest.xml
