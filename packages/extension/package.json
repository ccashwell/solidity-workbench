{
  "name": "solidity-workbench",
  "displayName": "Solidity Workbench",
  "description": "Modern Solidity IDE — Foundry-native LSP, test explorer, and static analysis",
  "version": "0.1.0",
  "publisher": "ccashwell",
  "license": "MIT",
  "icon": "resources/icon.png",
  "galleryBanner": {
    "color": "#1B1B1B",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ccashwell/solidity-workbench.git"
  },
  "bugs": {
    "url": "https://github.com/ccashwell/solidity-workbench/issues"
  },
  "homepage": "https://github.com/ccashwell/solidity-workbench#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Formatters",
    "Testing",
    "Debuggers"
  ],
  "keywords": [
    "solidity",
    "ethereum",
    "foundry",
    "forge",
    "smart contracts",
    "defi",
    "evm"
  ],
  "activationEvents": [
    "workspaceContains:**/foundry.toml",
    "workspaceContains:**/*.sol"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "solidity",
        "aliases": [
          "Solidity",
          "solidity"
        ],
        "extensions": [
          ".sol"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "solidity",
        "scopeName": "source.solidity",
        "path": "./syntaxes/solidity.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Solidity Workbench",
      "properties": {
        "solidity-workbench.foundryPath": {
          "type": "string",
          "default": "",
          "description": "Path to forge binary. Leave empty to use PATH."
        },
        "solidity-workbench.formatOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Run forge fmt on save."
        },
        "solidity-workbench.diagnostics.compileOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Run forge build on save for diagnostics."
        },
        "solidity-workbench.diagnostics.debounceMs": {
          "type": "number",
          "default": 500,
          "description": "Debounce time for real-time diagnostics (ms)."
        },
        "solidity-workbench.slither.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable slither static analysis integration."
        },
        "solidity-workbench.slither.path": {
          "type": "string",
          "default": "",
          "description": "Path to slither binary."
        },
        "solidity-workbench.aderyn.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable Aderyn (Cyfrin) static analysis integration. Runs on demand via the command palette and, when enabled, on save."
        },
        "solidity-workbench.aderyn.path": {
          "type": "string",
          "default": "",
          "description": "Path to the aderyn binary. Leave empty to use PATH."
        },
        "solidity-workbench.inlayHints.parameterNames": {
          "type": "boolean",
          "default": true,
          "description": "Show parameter name inlay hints in function calls."
        },
        "solidity-workbench.gasEstimates.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show gas estimate code lens on functions."
        },
        "solidity-workbench.test.verbosity": {
          "type": "number",
          "default": 2,
          "minimum": 0,
          "maximum": 5,
          "description": "Verbosity level for forge test output (0-5)."
        }
      }
    },
    "commands": [
      {
        "command": "solidity-workbench.build",
        "title": "Solidity Workbench: Build (forge build)",
        "icon": "$(gear)"
      },
      {
        "command": "solidity-workbench.test",
        "title": "Solidity Workbench: Run Tests (forge test)"
      },
      {
        "command": "solidity-workbench.testFile",
        "title": "Solidity Workbench: Run Tests in Current File"
      },
      {
        "command": "solidity-workbench.testFunction",
        "title": "Solidity Workbench: Run Test at Cursor"
      },
      {
        "command": "solidity-workbench.format",
        "title": "Solidity Workbench: Format (forge fmt)"
      },
      {
        "command": "solidity-workbench.gasSnapshot",
        "title": "Solidity Workbench: Gas Snapshot (forge snapshot)"
      },
      {
        "command": "solidity-workbench.gasClearHistory",
        "title": "Solidity Workbench: Clear Gas Regression Baseline"
      },
      {
        "command": "solidity-workbench.flatten",
        "title": "Solidity Workbench: Flatten Contract"
      },
      {
        "command": "solidity-workbench.inspectStorage",
        "title": "Solidity Workbench: Inspect Storage Layout"
      },
      {
        "command": "solidity-workbench.anvil.start",
        "title": "Solidity Workbench: Start Anvil"
      },
      {
        "command": "solidity-workbench.anvil.stop",
        "title": "Solidity Workbench: Stop Anvil"
      },
      {
        "command": "solidity-workbench.chisel.start",
        "title": "Solidity Workbench: Start Chisel REPL"
      },
      {
        "command": "solidity-workbench.chisel.startFork",
        "title": "Solidity Workbench: Start Chisel REPL (Fork)"
      },
      {
        "command": "solidity-workbench.chisel.sendSelection",
        "title": "Solidity Workbench: Send Selection to Chisel"
      },
      {
        "command": "solidity-workbench.restartServer",
        "title": "Solidity Workbench: Restart Language Server"
      },
      {
        "command": "solidity-workbench.coverage",
        "title": "Solidity Workbench: Run Coverage (forge coverage)"
      },
      {
        "command": "solidity-workbench.coverageClear",
        "title": "Solidity Workbench: Clear Coverage Highlights"
      },
      {
        "command": "solidity-workbench.slither",
        "title": "Solidity Workbench: Run Slither Analysis"
      },
      {
        "command": "solidity-workbench.aderyn",
        "title": "Solidity Workbench: Run Aderyn Analysis"
      },
      {
        "command": "solidity-workbench.subgraph.scaffold",
        "title": "Solidity Workbench: Generate Subgraph Scaffold"
      },
      {
        "command": "solidity-workbench.cast.sig",
        "title": "Solidity Workbench: Get Function Selector (cast sig)"
      },
      {
        "command": "solidity-workbench.cast.4byte",
        "title": "Solidity Workbench: Decode Selector (cast 4byte)"
      },
      {
        "command": "solidity-workbench.cast.calldataDecode",
        "title": "Solidity Workbench: Decode Calldata (cast calldata-decode)"
      },
      {
        "command": "solidity-workbench.cast.abiEncode",
        "title": "Solidity Workbench: ABI Encode (cast abi-encode)"
      },
      {
        "command": "solidity-workbench.cast.keccak",
        "title": "Solidity Workbench: Keccak256 Hash (cast keccak)"
      },
      {
        "command": "solidity-workbench.cast.toWei",
        "title": "Solidity Workbench: Convert to Wei (cast to-wei)"
      },
      {
        "command": "solidity-workbench.cast.fromWei",
        "title": "Solidity Workbench: Convert from Wei (cast from-wei)"
      },
      {
        "command": "solidity-workbench.cast.balance",
        "title": "Solidity Workbench: Check Balance (cast balance)"
      },
      {
        "command": "solidity-workbench.cast.storage",
        "title": "Solidity Workbench: Read Storage Slot (cast storage)"
      },
      {
        "command": "solidity-workbench.script.simulate",
        "title": "Solidity Workbench: Run Script — Simulate (forge script)"
      },
      {
        "command": "solidity-workbench.script.broadcast",
        "title": "Solidity Workbench: Run Script — Broadcast (forge script --broadcast)"
      },
      {
        "command": "solidity-workbench.script.resume",
        "title": "Solidity Workbench: Resume Script Broadcast (forge script --resume)"
      },
      {
        "command": "solidity-workbench.deploy.create",
        "title": "Solidity Workbench: Deploy Contract (forge create)"
      },
      {
        "command": "solidity-workbench.deploy.verify",
        "title": "Solidity Workbench: Verify Contract on Etherscan"
      },
      {
        "command": "solidity-workbench.deploy.verifyCheck",
        "title": "Solidity Workbench: Check Verification Status"
      },
      {
        "command": "solidity-workbench.debugTest",
        "title": "Solidity Workbench: Debug Test (forge test --debug)"
      },
      {
        "command": "solidity-workbench.debugScript",
        "title": "Solidity Workbench: Debug Script (forge debug)"
      },
      {
        "command": "solidity-workbench.debugTransaction",
        "title": "Solidity Workbench: Debug Transaction"
      },
      {
        "command": "solidity-workbench.inspectStoragePanel",
        "title": "Solidity Workbench: Storage Layout Visualization"
      },
      {
        "command": "solidity-workbench.copySelector",
        "title": "Solidity Workbench: Copy Selector to Clipboard"
      },
      {
        "command": "solidity-workbench.showOutput",
        "title": "Solidity Workbench: Show Output Channel"
      }
    ],
    "views": {
      "test": [
        {
          "id": "solidity-workbench-gas-profiler",
          "name": "Gas Profiler",
          "when": "workspaceFolderCount > 0"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "command": "solidity-workbench.testFunction",
          "when": "resourceLangId == solidity && resourceFilename =~ /\\.t\\.sol$/",
          "group": "solidity-workbench@1"
        },
        {
          "command": "solidity-workbench.cast.keccak",
          "when": "resourceLangId == solidity && editorHasSelection",
          "group": "solidity-workbench@2"
        },
        {
          "command": "solidity-workbench.cast.sig",
          "when": "resourceLangId == solidity && editorHasSelection",
          "group": "solidity-workbench@3"
        }
      ]
    },
    "taskDefinitions": [
      {
        "type": "forge",
        "required": [
          "command"
        ],
        "properties": {
          "command": {
            "type": "string",
            "description": "The forge command to run (build, test, script, etc.)"
          },
          "args": {
            "type": "array",
            "description": "Additional arguments"
          }
        }
      }
    ],
    "problemMatchers": [
      {
        "name": "forge",
        "owner": "solidity-workbench",
        "fileLocation": [
          "relative",
          "${workspaceFolder}"
        ],
        "pattern": {
          "regexp": "^Error \\(\\d+\\): (.*)$\\n --> (.*?):(\\d+):(\\d+):",
          "message": 1,
          "file": 2,
          "line": 3,
          "column": 4
        }
      }
    ]
  },
  "scripts": {
    "build": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap && esbuild ../server/src/server.ts --bundle --outfile=dist/server.js --external:vscode --format=cjs --platform=node --sourcemap",
    "watch": "pnpm build --watch",
    "package": "node ../../scripts/prepare-vsix-files.mjs && vsce package --no-dependencies",
    "build:test": "tsc -p tsconfig.test.json",
    "test:e2e": "pnpm build && pnpm build:test && node ./dist/test/runTest.js",
    "clean": "rm -rf dist *.tsbuildinfo README.md LICENSE CHANGELOG.md"
  },
  "dependencies": {
    "@solidity-workbench/common": "workspace:*",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.20.0",
    "glob": "^13.0.6",
    "mocha": "^11.7.5",
    "typescript": "^5.3.3"
  }
}
