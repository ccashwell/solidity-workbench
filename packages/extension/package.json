{
  "name": "solforge",
  "displayName": "Solforge",
  "description": "Modern Solidity IDE — Foundry-native LSP, test explorer, and static analysis",
  "version": "0.1.0",
  "publisher": "uniswap",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Formatters",
    "Testing",
    "Debuggers"
  ],
  "keywords": [
    "solidity",
    "ethereum",
    "foundry",
    "forge",
    "smart contracts",
    "defi",
    "evm"
  ],
  "activationEvents": [
    "workspaceContains:**/foundry.toml",
    "workspaceContains:**/*.sol"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "solidity",
        "aliases": ["Solidity", "solidity"],
        "extensions": [".sol"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "solidity",
        "scopeName": "source.solidity",
        "path": "./syntaxes/solidity.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Solforge",
      "properties": {
        "solforge.foundryPath": {
          "type": "string",
          "default": "",
          "description": "Path to forge binary. Leave empty to use PATH."
        },
        "solforge.formatOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Run forge fmt on save."
        },
        "solforge.diagnostics.compileOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Run forge build on save for diagnostics."
        },
        "solforge.diagnostics.debounceMs": {
          "type": "number",
          "default": 500,
          "description": "Debounce time for real-time diagnostics (ms)."
        },
        "solforge.slither.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable slither static analysis integration."
        },
        "solforge.slither.path": {
          "type": "string",
          "default": "",
          "description": "Path to slither binary."
        },
        "solforge.inlayHints.parameterNames": {
          "type": "boolean",
          "default": true,
          "description": "Show parameter name inlay hints in function calls."
        },
        "solforge.inlayHints.variableTypes": {
          "type": "boolean",
          "default": false,
          "description": "Show inferred type inlay hints for variables."
        },
        "solforge.gasEstimates.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show gas estimate code lens on functions."
        },
        "solforge.test.verbosity": {
          "type": "number",
          "default": 2,
          "minimum": 0,
          "maximum": 5,
          "description": "Verbosity level for forge test output (0-5)."
        }
      }
    },
    "commands": [
      {
        "command": "solforge.build",
        "title": "Solforge: Build (forge build)",
        "icon": "$(gear)"
      },
      {
        "command": "solforge.test",
        "title": "Solforge: Run Tests (forge test)"
      },
      {
        "command": "solforge.testFile",
        "title": "Solforge: Run Tests in Current File"
      },
      {
        "command": "solforge.testFunction",
        "title": "Solforge: Run Test at Cursor"
      },
      {
        "command": "solforge.format",
        "title": "Solforge: Format (forge fmt)"
      },
      {
        "command": "solforge.gasSnapshot",
        "title": "Solforge: Gas Snapshot (forge snapshot)"
      },
      {
        "command": "solforge.flatten",
        "title": "Solforge: Flatten Contract"
      },
      {
        "command": "solforge.inspectStorage",
        "title": "Solforge: Inspect Storage Layout"
      },
      {
        "command": "solforge.anvil.start",
        "title": "Solforge: Start Anvil"
      },
      {
        "command": "solforge.anvil.stop",
        "title": "Solforge: Stop Anvil"
      },
      {
        "command": "solforge.restartServer",
        "title": "Solforge: Restart Language Server"
      },
      {
        "command": "solforge.coverage",
        "title": "Solforge: Run Coverage (forge coverage)"
      },
      {
        "command": "solforge.coverageClear",
        "title": "Solforge: Clear Coverage Highlights"
      },
      {
        "command": "solforge.slither",
        "title": "Solforge: Run Slither Analysis"
      },
      {
        "command": "solforge.cast.sig",
        "title": "Solforge: Get Function Selector (cast sig)"
      },
      {
        "command": "solforge.cast.4byte",
        "title": "Solforge: Decode Selector (cast 4byte)"
      },
      {
        "command": "solforge.cast.calldataDecode",
        "title": "Solforge: Decode Calldata (cast calldata-decode)"
      },
      {
        "command": "solforge.cast.abiEncode",
        "title": "Solforge: ABI Encode (cast abi-encode)"
      },
      {
        "command": "solforge.cast.keccak",
        "title": "Solforge: Keccak256 Hash (cast keccak)"
      },
      {
        "command": "solforge.cast.toWei",
        "title": "Solforge: Convert to Wei (cast to-wei)"
      },
      {
        "command": "solforge.cast.fromWei",
        "title": "Solforge: Convert from Wei (cast from-wei)"
      },
      {
        "command": "solforge.cast.balance",
        "title": "Solforge: Check Balance (cast balance)"
      },
      {
        "command": "solforge.cast.storage",
        "title": "Solforge: Read Storage Slot (cast storage)"
      },
      {
        "command": "solforge.script.simulate",
        "title": "Solforge: Run Script — Simulate (forge script)"
      },
      {
        "command": "solforge.script.broadcast",
        "title": "Solforge: Run Script — Broadcast (forge script --broadcast)"
      },
      {
        "command": "solforge.script.resume",
        "title": "Solforge: Resume Script Broadcast (forge script --resume)"
      },
      {
        "command": "solforge.deploy.create",
        "title": "Solforge: Deploy Contract (forge create)"
      },
      {
        "command": "solforge.deploy.verify",
        "title": "Solforge: Verify Contract on Etherscan"
      },
      {
        "command": "solforge.deploy.verifyCheck",
        "title": "Solforge: Check Verification Status"
      },
      {
        "command": "solforge.debugTest",
        "title": "Solforge: Debug Test (forge test --debug)"
      },
      {
        "command": "solforge.debugScript",
        "title": "Solforge: Debug Script (forge debug)"
      },
      {
        "command": "solforge.debugTransaction",
        "title": "Solforge: Debug Transaction"
      },
      {
        "command": "solforge.inspectStoragePanel",
        "title": "Solforge: Storage Layout Visualization"
      },
      {
        "command": "solforge.inheritanceGraph",
        "title": "Solforge: Show Inheritance Graph"
      },
      {
        "command": "solforge.showAbi",
        "title": "Solforge: Show ABI Explorer"
      },
      {
        "command": "solforge.gasDiff",
        "title": "Solforge: Gas Diff (Compare Snapshots)"
      },
      {
        "command": "solforge.gasDiffRefresh",
        "title": "Solforge: Refresh Gas Diff",
        "icon": "$(refresh)"
      },
      {
        "command": "solforge.chisel.start",
        "title": "Solforge: Start Chisel REPL"
      },
      {
        "command": "solforge.chisel.startFork",
        "title": "Solforge: Start Chisel REPL (Fork)"
      },
      {
        "command": "solforge.chisel.sendSelection",
        "title": "Solforge: Send Selection to Chisel"
      },
      {
        "command": "solforge.copySelector",
        "title": "Solforge: Copy Selector"
      }
    ],
    "breakpoints": [
      { "language": "solidity" }
    ],
    "debuggers": [
      {
        "type": "solforge",
        "label": "Solforge Debugger",
        "languages": ["solidity"],
        "configurationAttributes": {
          "launch": {
            "required": ["mode"],
            "properties": {
              "mode": {
                "type": "string",
                "description": "Debug mode: test, script, or transaction",
                "enum": ["test", "script", "transaction"]
              },
              "testFunction": {
                "type": "string",
                "description": "Test function name for mode=test"
              },
              "scriptFile": {
                "type": "string",
                "description": "Script file path for mode=script"
              },
              "txHash": {
                "type": "string",
                "description": "Transaction hash for mode=transaction"
              },
              "rpcUrl": {
                "type": "string",
                "description": "RPC URL for mode=transaction",
                "default": "http://127.0.0.1:8545"
              }
            }
          }
        },
        "configurationSnippets": [
          {
            "label": "Solforge: Debug Test",
            "description": "Debug a Foundry test function",
            "body": {
              "type": "solforge",
              "request": "launch",
              "name": "Debug Forge Test",
              "mode": "test",
              "testFunction": "${1:test_myFunction}"
            }
          },
          {
            "label": "Solforge: Debug Script",
            "description": "Debug a Foundry script",
            "body": {
              "type": "solforge",
              "request": "launch",
              "name": "Debug Forge Script",
              "mode": "script",
              "scriptFile": "^\"${2:\\${file\\}}\""
            }
          },
          {
            "label": "Solforge: Debug Transaction",
            "description": "Replay and debug a transaction",
            "body": {
              "type": "solforge",
              "request": "launch",
              "name": "Debug Transaction",
              "mode": "transaction",
              "txHash": "${1:0x...}",
              "rpcUrl": "${2:http://127.0.0.1:8545}"
            }
          }
        ]
      }
    ],
    "views": {
      "test": [
        {
          "id": "solforge-gas-profiler",
          "name": "Gas Profiler",
          "when": "workspaceFolderCount > 0"
        },
        {
          "id": "solforge-gas-diff",
          "name": "Gas Diff",
          "when": "workspaceFolderCount > 0"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "command": "solforge.testFunction",
          "when": "resourceLangId == solidity && resourceFilename =~ /\\.t\\.sol$/",
          "group": "solforge@1"
        },
        {
          "command": "solforge.cast.keccak",
          "when": "resourceLangId == solidity && editorHasSelection",
          "group": "solforge@2"
        },
        {
          "command": "solforge.cast.sig",
          "when": "resourceLangId == solidity && editorHasSelection",
          "group": "solforge@3"
        },
        {
          "command": "solforge.showAbi",
          "when": "resourceLangId == solidity",
          "group": "solforge@4"
        },
        {
          "command": "solforge.inheritanceGraph",
          "when": "resourceLangId == solidity",
          "group": "solforge@5"
        },
        {
          "command": "solforge.chisel.sendSelection",
          "when": "resourceLangId == solidity && editorHasSelection",
          "group": "solforge@6"
        }
      ]
    },
    "taskDefinitions": [
      {
        "type": "forge",
        "required": ["command"],
        "properties": {
          "command": {
            "type": "string",
            "description": "The forge command to run (build, test, script, etc.)"
          },
          "args": {
            "type": "array",
            "description": "Additional arguments"
          }
        }
      }
    ],
    "problemMatchers": [
      {
        "name": "forge",
        "owner": "solforge",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^Error \\(\\d+\\): (.*)$\\n --> (.*?):(\\d+):(\\d+):",
          "message": 1,
          "file": 2,
          "line": 3,
          "column": 4
        }
      }
    ]
  },
  "scripts": {
    "build": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "watch": "pnpm build --watch",
    "package": "vsce package --no-dependencies",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@solforge/common": "workspace:*",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.3"
  }
}
