{
  "name": "solidity-workbench",
  "displayName": "Solidity Workbench",
  "description": "Modern Solidity IDE Integration with Foundry-native LSP, test explorer, and static analysis",
  "version": "0.6.2",
  "publisher": "ccashwell",
  "license": "MIT",
  "icon": "resources/icon.png",
  "galleryBanner": {
    "color": "#1b1b1b",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ccashwell/solidity-workbench.git"
  },
  "bugs": {
    "url": "https://github.com/ccashwell/solidity-workbench/issues"
  },
  "homepage": "https://github.com/ccashwell/solidity-workbench#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Formatters",
    "Testing"
  ],
  "keywords": [
    "solidity",
    "foundry",
    "forge"
  ],
  "activationEvents": [
    "workspaceContains:**/foundry.toml",
    "workspaceContains:**/*.sol"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "solidity",
        "aliases": [
          "Solidity",
          "solidity"
        ],
        "extensions": [
          ".sol"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "solidity",
        "scopeName": "source.solidity",
        "path": "./syntaxes/solidity.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Solidity Workbench",
      "properties": {
        "solidity-workbench.foundryPath": {
          "type": "string",
          "default": "",
          "description": "Path to forge binary. Leave empty to use PATH."
        },
        "solidity-workbench.castPath": {
          "type": "string",
          "default": "",
          "description": "Path to cast binary. Leave empty to use PATH."
        },
        "solidity-workbench.formatOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Run forge fmt on save."
        },
        "solidity-workbench.diagnostics.compileOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Run forge build on save for diagnostics."
        },
        "solidity-workbench.diagnostics.debounceMs": {
          "type": "number",
          "default": 500,
          "description": "Debounce time for real-time diagnostics (ms)."
        },
        "solidity-workbench.slither.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable slither static analysis integration."
        },
        "solidity-workbench.slither.path": {
          "type": "string",
          "default": "",
          "description": "Path to slither binary."
        },
        "solidity-workbench.aderyn.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable Aderyn (Cyfrin) static analysis integration. Runs on demand via the command palette and, when enabled, on save."
        },
        "solidity-workbench.aderyn.path": {
          "type": "string",
          "default": "",
          "description": "Path to the aderyn binary. Leave empty to use PATH."
        },
        "solidity-workbench.wake.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable Wake (Ackee Blockchain) static analysis integration. Runs on demand via the command palette and, when enabled, on save."
        },
        "solidity-workbench.wake.path": {
          "type": "string",
          "default": "",
          "description": "Path to the wake binary. Leave empty to use PATH."
        },
        "solidity-workbench.mythril.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable Mythril (ConsenSys) symbolic-execution integration. Mythril is slow (often tens of seconds to minutes per contract); the on-save trigger is opt-in. Runs against the active editor's Solidity file."
        },
        "solidity-workbench.mythril.path": {
          "type": "string",
          "default": "",
          "description": "Path to the myth binary. Leave empty to use PATH."
        },
        "solidity-workbench.inlayHints.parameterNames": {
          "type": "boolean",
          "default": true,
          "description": "Show parameter name inlay hints in function calls."
        },
        "solidity-workbench.gasEstimates.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show gas estimate code lens on functions."
        },
        "solidity-workbench.test.verbosity": {
          "type": "number",
          "default": 2,
          "minimum": 0,
          "maximum": 5,
          "description": "Verbosity level for forge test output (0-5)."
        }
      }
    },
    "commands": [
      {
        "command": "solidity-workbench.build",
        "title": "Solidity Workbench: Build (forge build)",
        "icon": "$(gear)"
      },
      {
        "command": "solidity-workbench.test",
        "title": "Solidity Workbench: Run Tests (forge test)"
      },
      {
        "command": "solidity-workbench.testFile",
        "title": "Solidity Workbench: Run Tests in Current File"
      },
      {
        "command": "solidity-workbench.testFunction",
        "title": "Solidity Workbench: Run Test at Cursor"
      },
      {
        "command": "solidity-workbench.format",
        "title": "Solidity Workbench: Format (forge fmt)"
      },
      {
        "command": "solidity-workbench.gasSnapshot",
        "title": "Solidity Workbench: Gas Snapshot (forge snapshot)"
      },
      {
        "command": "solidity-workbench.gasClearHistory",
        "title": "Solidity Workbench: Clear Gas Regression Baseline"
      },
      {
        "command": "solidity-workbench.flatten",
        "title": "Solidity Workbench: Flatten Contract"
      },
      {
        "command": "solidity-workbench.inspectStorage",
        "title": "Solidity Workbench: Inspect Storage Layout"
      },
      {
        "command": "solidity-workbench.anvil.start",
        "title": "Solidity Workbench: Start Anvil Instance",
        "icon": "$(add)"
      },
      {
        "command": "solidity-workbench.anvil.stop",
        "title": "Solidity Workbench: Stop Anvil Instance"
      },
      {
        "command": "solidity-workbench.anvil.stopAll",
        "title": "Solidity Workbench: Stop All Anvil Instances",
        "icon": "$(debug-stop)"
      },
      {
        "command": "solidity-workbench.anvil.startPreset",
        "title": "Solidity Workbench: Start Anvil Preset (Multi-Chain)",
        "icon": "$(layers)"
      },
      {
        "command": "solidity-workbench.anvil.editPresets",
        "title": "Solidity Workbench: Edit Anvil Presets"
      },
      {
        "command": "solidity-workbench.anvil.showOutput",
        "title": "Solidity Workbench: Show Anvil Output"
      },
      {
        "command": "solidity-workbench.anvil.copyRpcUrl",
        "title": "Copy RPC URL"
      },
      {
        "command": "solidity-workbench.chisel.start",
        "title": "Solidity Workbench: Start Chisel REPL"
      },
      {
        "command": "solidity-workbench.chisel.startFork",
        "title": "Solidity Workbench: Start Chisel REPL (Fork)"
      },
      {
        "command": "solidity-workbench.chisel.sendSelection",
        "title": "Solidity Workbench: Send Selection to Chisel"
      },
      {
        "command": "solidity-workbench.restartServer",
        "title": "Solidity Workbench: Restart Language Server"
      },
      {
        "command": "solidity-workbench.coverage",
        "title": "Solidity Workbench: Run Coverage (forge coverage)"
      },
      {
        "command": "solidity-workbench.coverageClear",
        "title": "Solidity Workbench: Clear Coverage Highlights"
      },
      {
        "command": "solidity-workbench.slither",
        "title": "Solidity Workbench: Run Slither Analysis"
      },
      {
        "command": "solidity-workbench.aderyn",
        "title": "Solidity Workbench: Run Aderyn Analysis"
      },
      {
        "command": "solidity-workbench.wake",
        "title": "Solidity Workbench: Run Wake Analysis"
      },
      {
        "command": "solidity-workbench.mythril",
        "title": "Solidity Workbench: Run Mythril Analysis (current file)"
      },
      {
        "command": "solidity-workbench.indexer.scaffold",
        "title": "Solidity Workbench: Generate Indexer Scaffold (Graph / Ponder / Envio)"
      },
      {
        "command": "solidity-workbench.subgraph.scaffold",
        "title": "Solidity Workbench: Generate Subgraph Scaffold"
      },
      {
        "command": "solidity-workbench.cast.sig",
        "title": "Solidity Workbench: Get Function Selector (cast sig)"
      },
      {
        "command": "solidity-workbench.cast.4byte",
        "title": "Solidity Workbench: Decode Selector (cast 4byte)"
      },
      {
        "command": "solidity-workbench.cast.calldataDecode",
        "title": "Solidity Workbench: Decode Calldata (cast calldata-decode)"
      },
      {
        "command": "solidity-workbench.cast.abiEncode",
        "title": "Solidity Workbench: ABI Encode (cast abi-encode)"
      },
      {
        "command": "solidity-workbench.cast.keccak",
        "title": "Solidity Workbench: Keccak256 Hash (cast keccak)"
      },
      {
        "command": "solidity-workbench.cast.toWei",
        "title": "Solidity Workbench: Convert to Wei (cast to-wei)"
      },
      {
        "command": "solidity-workbench.cast.fromWei",
        "title": "Solidity Workbench: Convert from Wei (cast from-wei)"
      },
      {
        "command": "solidity-workbench.cast.balance",
        "title": "Solidity Workbench: Check Balance (cast balance)"
      },
      {
        "command": "solidity-workbench.cast.storage",
        "title": "Solidity Workbench: Read Storage Slot (cast storage)"
      },
      {
        "command": "solidity-workbench.script.simulate",
        "title": "Solidity Workbench: Run Script — Simulate (forge script)"
      },
      {
        "command": "solidity-workbench.script.broadcast",
        "title": "Solidity Workbench: Run Script — Broadcast (forge script --broadcast)"
      },
      {
        "command": "solidity-workbench.script.resume",
        "title": "Solidity Workbench: Resume Script Broadcast (forge script --resume)"
      },
      {
        "command": "solidity-workbench.deploy.create",
        "title": "Solidity Workbench: Deploy Contract (forge create)"
      },
      {
        "command": "solidity-workbench.deploy.verify",
        "title": "Solidity Workbench: Verify Contract on Etherscan"
      },
      {
        "command": "solidity-workbench.deploy.verifyCheck",
        "title": "Solidity Workbench: Check Verification Status"
      },
      {
        "command": "solidity-workbench.debugTest",
        "title": "Solidity Workbench: Debug Test (forge test --debug)"
      },
      {
        "command": "solidity-workbench.debugScript",
        "title": "Solidity Workbench: Debug Script (forge debug)"
      },
      {
        "command": "solidity-workbench.debugTransaction",
        "title": "Solidity Workbench: Debug Transaction"
      },
      {
        "command": "solidity-workbench.inspectStoragePanel",
        "title": "Solidity Workbench: Storage Layout Visualization"
      },
      {
        "command": "solidity-workbench.copySelector",
        "title": "Solidity Workbench: Copy Selector to Clipboard"
      },
      {
        "command": "solidity-workbench.showOutput",
        "title": "Solidity Workbench: Show Output Channel"
      },
      {
        "command": "solidity-workbench.inheritanceGraph",
        "title": "Solidity Workbench: Show Inheritance Graph"
      },
      {
        "command": "solidity-workbench.showAbi",
        "title": "Solidity Workbench: Show ABI Explorer"
      },
      {
        "command": "solidity-workbench.gasDiff",
        "title": "Solidity Workbench: Gas Diff (Compare Snapshots)"
      },
      {
        "command": "solidity-workbench.gasDiffRefresh",
        "title": "Solidity Workbench: Refresh Gas Diff",
        "icon": "$(refresh)"
      },
      {
        "command": "solidity-workbench.remoteChain.open",
        "title": "Solidity Workbench: Open Remote Chain UI"
      },
      {
        "command": "solidity-workbench.viewIR",
        "title": "Solidity Workbench: View IR (Yul / Assembly)"
      }
    ],
    "views": {
      "test": [
        {
          "id": "solidity-workbench-gas-profiler",
          "name": "Gas Profiler",
          "when": "workspaceFolderCount > 0"
        },
        {
          "id": "solidity-workbench-gas-diff",
          "name": "Gas Diff",
          "when": "workspaceFolderCount > 0"
        },
        {
          "id": "solidity-workbench-anvil-instances",
          "name": "Anvil Instances",
          "when": "workspaceFolderCount > 0"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "solidity-workbench.anvil.start",
          "when": "view == solidity-workbench-anvil-instances",
          "group": "navigation@1"
        },
        {
          "command": "solidity-workbench.anvil.startPreset",
          "when": "view == solidity-workbench-anvil-instances",
          "group": "navigation@2"
        },
        {
          "command": "solidity-workbench.anvil.stopAll",
          "when": "view == solidity-workbench-anvil-instances",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "solidity-workbench.anvil.copyRpcUrl",
          "when": "view == solidity-workbench-anvil-instances && viewItem == anvilInstance",
          "group": "inline"
        },
        {
          "command": "solidity-workbench.anvil.stop",
          "when": "view == solidity-workbench-anvil-instances && viewItem == anvilInstance"
        }
      ],
      "editor/context": [
        {
          "command": "solidity-workbench.testFunction",
          "when": "resourceLangId == solidity && resourceFilename =~ /\\.t\\.sol$/",
          "group": "solidity-workbench@1"
        },
        {
          "command": "solidity-workbench.cast.keccak",
          "when": "resourceLangId == solidity && editorHasSelection",
          "group": "solidity-workbench@2"
        },
        {
          "command": "solidity-workbench.cast.sig",
          "when": "resourceLangId == solidity && editorHasSelection",
          "group": "solidity-workbench@3"
        },
        {
          "command": "solidity-workbench.showAbi",
          "when": "resourceLangId == solidity",
          "group": "solidity-workbench@4"
        },
        {
          "command": "solidity-workbench.inheritanceGraph",
          "when": "resourceLangId == solidity",
          "group": "solidity-workbench@5"
        },
        {
          "command": "solidity-workbench.viewIR",
          "when": "resourceLangId == solidity",
          "group": "solidity-workbench@5a"
        },
        {
          "command": "solidity-workbench.chisel.sendSelection",
          "when": "resourceLangId == solidity && editorHasSelection",
          "group": "solidity-workbench@6"
        }
      ]
    },
    "breakpoints": [
      {
        "language": "solidity"
      }
    ],
    "debuggers": [
      {
        "type": "solidity-workbench",
        "label": "Solidity (Foundry)",
        "languages": [
          "solidity"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [],
            "properties": {
              "program": {
                "type": "string",
                "description": "Path to the Solidity contract or test file to debug.",
                "default": "${file}"
              },
              "test": {
                "type": "string",
                "description": "Test function name to debug (e.g. test_increment). When omitted, the active editor's test under the cursor is used."
              },
              "stopOnEntry": {
                "type": "boolean",
                "description": "Stop at the first opcode of the transaction.",
                "default": true
              },
              "traceFile": {
                "type": "string",
                "description": "Optional path to a pre-saved EVM trace JSON (e.g. `cast run --json <txhash> > trace.json`). When supplied, the adapter steps through this trace. Mutually exclusive with `txHash` — `traceFile` wins if both are set."
              },
              "txHash": {
                "type": "string",
                "description": "Transaction hash to fetch live via `cast run --json <txhash>` at launch time. Eliminates the save-trace-to-file two-step. Combine with `rpcUrl` to point at a non-default endpoint."
              },
              "rpcUrl": {
                "type": "string",
                "description": "Optional `--rpc-url` passed to `cast run`. Defaults to whatever cast picks up (typically a local Anvil at 127.0.0.1:8545)."
              },
              "artifact": {
                "type": "string",
                "description": "Optional path to a forge artifact JSON (`out/<file>.sol/<Contract>.json`). Required for source-position-aware stepping — the adapter reads deployedBytecode + sourceMap + the source list from here.",
                "default": "${workspaceFolder}/out/${fileBasename}/${fileBasenameNoExtension}.json"
              },
              "projectRoot": {
                "type": "string",
                "description": "Project root used to resolve the artifact's relative source paths. Defaults to the workspace folder.",
                "default": "${workspaceFolder}"
              },
              "contracts": {
                "type": "array",
                "description": "Auxiliary contracts that may be CALLed during the trace. Each entry pairs a deployed `address` with the path to its forge `artifact`. The adapter switches the active source map / storage layout / disassembly when the trace enters a CALL whose target matches a listed address — without these, deeper frames render as label-only frames.",
                "items": {
                  "type": "object",
                  "required": ["address", "artifact"],
                  "properties": {
                    "address": { "type": "string", "description": "0x-prefixed deployed address (any case)." },
                    "artifact": { "type": "string", "description": "Path to the contract's forge artifact JSON." },
                    "projectRoot": { "type": "string", "description": "Optional override for resolving the artifact's relative source paths." }
                  }
                }
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "solidity-workbench",
            "request": "launch",
            "name": "Debug Solidity test",
            "program": "${file}",
            "stopOnEntry": true
          }
        ],
        "configurationSnippets": [
          {
            "label": "Solidity Workbench: Debug Foundry Test",
            "description": "Launch a Foundry test under the EVM debug adapter (step-through tracing).",
            "body": {
              "type": "solidity-workbench",
              "request": "launch",
              "name": "Debug ${1:test_name}",
              "program": "^\"\\${file}\"",
              "test": "${1:test_name}",
              "stopOnEntry": true
            }
          }
        ]
      }
    ],
    "taskDefinitions": [
      {
        "type": "forge",
        "required": [
          "command"
        ],
        "properties": {
          "command": {
            "type": "string",
            "description": "The forge command to run (build, test, script, etc.)"
          },
          "args": {
            "type": "array",
            "description": "Additional arguments"
          }
        }
      }
    ],
    "problemMatchers": [
      {
        "name": "forge",
        "owner": "solidity-workbench",
        "fileLocation": [
          "relative",
          "${workspaceFolder}"
        ],
        "pattern": {
          "regexp": "^Error \\(\\d+\\): (.*)$\\n --> (.*?):(\\d+):(\\d+):",
          "message": 1,
          "file": 2,
          "line": 3,
          "column": 4
        }
      }
    ]
  },
  "scripts": {
    "build": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap && esbuild ../server/src/server.ts --bundle --outfile=dist/server.js --external:vscode --format=cjs --platform=node --sourcemap && esbuild ../server/src/parser/parser-worker.ts --bundle --outfile=dist/parser-worker.js --external:vscode --format=cjs --platform=node",
    "watch": "pnpm build --watch",
    "package": "node ../../scripts/prepare-vsix-files.mjs && vsce package --no-dependencies",
    "publish:ovsx": "ovsx publish solidity-workbench-$npm_package_version.vsix",
    "build:test": "tsc -p tsconfig.test.json",
    "test:e2e": "pnpm build && pnpm build:test && node ./dist/test/runTest.js",
    "clean": "rm -rf dist *.tsbuildinfo README.md LICENSE CHANGELOG.md"
  },
  "dependencies": {
    "@solidity-workbench/common": "workspace:*",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.25.0",
    "glob": "^13.0.6",
    "mocha": "^11.7.5",
    "ovsx": "^0.10.11",
    "typescript": "^5.3.3"
  }
}
